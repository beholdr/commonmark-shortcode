{
    "name": "commonmark-shortcode",
    "image": "mcr.microsoft.com/devcontainers/php:3-8.5-trixie",
    "containerEnv": {
        "XDEBUG_MODE": "off"
    },
    "features": {
        "ghcr.io/danzilberdan/devcontainers/opencode:0": {}
    },
    "mounts": [
        "source=${localEnv:HOME}/.local/share/opencode/auth.json,target=/mnt/opencode-auth.json,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "EditorConfig.EditorConfig",
                "liamhammett.temphpest",
                "neilbrayfield.php-docblocker",
                "shardulm94.trailing-spaces",
                "sst-dev.opencode"
            ]
        }
    }
}

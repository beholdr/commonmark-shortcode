{
    "name": "beholdr/commonmark-shortcode",
    "description": "Shortcodes extension for CommonMark",
    "keywords": [
        "shortcode",
        "commonmark"
    ],
    "homepage": "https://github.com/beholdr/commonmark-shortcode",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexander Shabunevich",
            "email": "loonar@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "league/commonmark": "^2.8"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Beholdr\\CommonmarkShortcode\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Beholdr\\CommonmarkShortcode\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
